<mvc:View
    xmlns:smarttable="sap.ui.comp.smarttable"
    controllerName="zinvoices.controller.Main"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
>
    <Page
        id="page"
        title="Display Northwind Invoices"
        showHeader="false"
    >
        <smarttable:SmartTable
            id="smartTable"
            entitySet="Invoices"
            tableType="ResponsiveTable"
            enableAutoBinding="true"
            header="Invoices" 
            class="sapUiResponsiveContentPadding"
            initiallyVisibleFields="CustomerID,CustomerName,OrderID,Salesperson,ShipName,Freight,UnitPrice,ExtendedPrice"
        />
    </Page>
</mvc:View>
